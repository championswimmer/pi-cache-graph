{
  "name": "pi-cache-graph",
  "version": "0.2.0",
  "description": "Pi extension for visualizing context cache distribution and statistics",
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "dev": "pi -e .",
    "check": "tsc --noEmit",
    "fixtures:generate": "node scripts/generate-fixtures.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "cache",
    "tui"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.70.6",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-tui": "^0.70.6",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "author": "Arnav Gupta <arnav@championswimmer.in>",
  "repository": {
    "type": "git",
    "url": "https://github.com/championswimmer/pi-cache-graph.git"
  },
  "files": [
    "src",
    "index.ts",
    "tsconfig.json"
  ]
}
